## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

## imgui.ini zit soms nog verkeerd in cache. om dit te clearen:
## RMB op solution folder -> Git bash here (Je hebt Git nodig)
## type in git bash: git rm --cached imgui.ini rm 'imgui.ini'

## use git clean -dfX to reset to the updated gitIgnore

## to reset:
## git rm -rf --cached .
## git add .

# Exluding custom folders
saved files/
local resources

# Exluding who knows what
*.ini
out
out/
enc_temp_folder/

recoveries/
exports/
temp/
user profiles/
prefs.ini
**/*_tmp
**/temp/

# doxygen excludes
Documentation/html

# excluding build files
build

# visual studio excludes
.vs/
**.sln
**.vcxproj
**.vcxproj.user
**.vcxproj.filters

# dependencies excludes
dependencies/**.ini
dependencies/**.exe
dependencies/temp
dependencies/user profiles
dependencies/Lightbender_DLL.dll
dependencies/Lightbender_UnityPlugin.dll

# Unity excludes

# excluding the dlls that get copied to Unity
/LB-Unity-Project/Assets/Plugins/x86_64/**

# Unity excludes
/LB-Unity-Project/[Ll]ibrary/
/LB-Unity-Project/[Tt]emp/
/LB-Unity-Project/[Oo]bj/
/LB-Unity-Project/[Bb]uild/
/LB-Unity-Project/[Bb]uilds/
/LB-Unity-Project/[Ll]ogs/
/LB-Unity-Project/[Uu]ser[Ss]ettings/
/LB-Unity-Project/[Mm]emoryCaptures/
/LB-Unity-Project/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /LB-Unity-Project/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/LB-Unity-Project/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/LB-Unity-Project/.vs/

# Gradle cache directory
/LB-Unity-Project/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/LB-Unity-Project/ExportedObj/
/LB-Unity-Project/.consulo/
/LB-Unity-Project/*.csproj
/LB-Unity-Project/*.unityproj
/LB-Unity-Project/*.sln
/LB-Unity-Project/*.suo
/LB-Unity-Project/*.tmp
/LB-Unity-Project/*.user
/LB-Unity-Project/*.userprefs
/LB-Unity-Project/*.pidb
/LB-Unity-Project/*.booproj
/LB-Unity-Project/*.svd
/LB-Unity-Project/*.pdb
/LB-Unity-Project/*.mdb
/LB-Unity-Project/*.opendb
/LB-Unity-Project/*.VC.db

# Unity3D generated meta files
/LB-Unity-Project/*.meta
/LB-Unity-Project/*.pidb.meta
/LB-Unity-Project/*.pdb.meta
/LB-Unity-Project/*.mdb.meta

# Unity3D generated file on crash reports
/LB-Unity-Project/sysinfo.txt

# Builds
/LB-Unity-Project/*.apk
/LB-Unity-Project/*.aab
/LB-Unity-Project/*.unitypackage
/LB-Unity-Project/*.app

# Crashlytics generated file
/LB-Unity-Project/crashlytics-build.properties

# Packed Addressables
/LB-Unity-Project/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/LB-Unity-Project/[Aa]ssets/[Ss]treamingAssets/aa.meta
/LB-Unity-Project/[Aa]ssets/[Ss]treamingAssets/aa/*